# =============================================================================
# RestaurantOS Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# 🔐 SECURITY WARNING:
# Never commit .env files. Never use default secrets in production.
# Generate all secrets with: openssl rand -base64 32
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# Start PostgreSQL locally: docker compose up postgres -d
# Or use your own PostgreSQL instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurantos?schema=public"

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Minimum length: 32 characters
JWT_SECRET="change-this-to-a-very-long-random-string"
REFRESH_SECRET="change-this-to-another-long-random-string"

# Token expiry durations
# Format: numeric + unit (s=seconds, m=minutes, h=hours, d=days)
JWT_EXPIRES_IN="15m"        # Access token lifetime (short-lived)
JWT_REFRESH_EXPIRES_IN="7d" # Refresh token lifetime

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development        # Set to "production" for deployment
FRONTEND_URL="http://localhost:5173"  # CORS origin (comma-separated for multiple)
UPLOAD_DIR="./uploads"      # Where menu images are stored
BACKUP_DIR="./backups"      # Where DB backups are saved

# ─── Stripe (Optional) ───────────────────────────────────────────────────────
# Required for payment processing. Get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Sentry (Optional) ───────────────────────────────────────────────────────
# Error monitoring. Get from https://sentry.io/settings/account/api/
# SENTRY_DSN="https://key@o0.ingest.sentry.io/0"
