# =============================================================================
# RestaurantOS — Docker Compose Environment Configuration
# =============================================================================
# Copy this file to .env (same directory) and fill in your values before:
#   docker compose up -d
#
# For production with Caddy (HTTPS):
#   docker compose --profile production up -d
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 24
DB_PASSWORD="change-this-to-a-strong-password"

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-very-long-random-string-min-32-chars"
REFRESH_SECRET="change-this-to-another-long-random-string-min-32-chars"

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=3001
FRONTEND_URL="https://your-domain.com"

# ─── Client ──────────────────────────────────────────────────────────────────
CLIENT_PORT=80
